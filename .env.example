# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/trident_leasing

# JWT signing secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# Port the Express API server listens on (default: 3001)
PORT=3001

# Allowed CORS origin for the frontend (default: http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173

# Vite frontend env vars (prefix with VITE_ to expose to the browser)
# These are no longer required now that auth is handled by the Express backend,
# but kept here for reference if Supabase is used for other features.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
